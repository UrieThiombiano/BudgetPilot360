# BudgetPilot360 — variables d'environnement frontend de PRODUCTION (Vercel).
# À saisir dans Vercel > Project Settings > Environment Variables (scope Production).
# Seule la clé "anon" (publique, protégée par la RLS) va côté client —
# JAMAIS la service_role.

VITE_SUPABASE_URL=https://<ref-projet-prod>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon key du projet PROD>

# URL publique du backend FastAPI (service Render/Railway)
VITE_API_URL=https://budgetpilot360-api.onrender.com
