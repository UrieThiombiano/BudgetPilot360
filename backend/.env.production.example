# BudgetPilot360 — variables d'environnement backend de PRODUCTION (Render/Railway).
# À saisir dans le dashboard de l'hébergeur — ce fichier n'est qu'un modèle, ne
# JAMAIS commiter de vraies valeurs. Utiliser le projet Supabase de PROD.

SUPABASE_URL=https://<ref-projet-prod>.supabase.co
SUPABASE_ANON_KEY=<anon key du projet PROD>
SUPABASE_SERVICE_ROLE_KEY=<service_role du projet PROD — backend uniquement>
SUPABASE_JWT_SECRET=

DATABASE_URL=postgresql+asyncpg://postgres.<ref-prod>:<MDP>@aws-0-eu-west-2.pooler.supabase.com:6543/postgres

MISTRAL_API_KEY=<clé Mistral de prod (distincte de dev)>
MISTRAL_MODEL=mistral-small-latest

# Linux : les libs Pango sont dans l'image Docker, laisser vide
WEASYPRINT_DLL_DIRECTORIES=

ENVIRONMENT=production
# CORS restreint — le(s) domaine(s) frontend de prod, séparés par des virgules
FRONTEND_URL=https://budgetpilot360.vercel.app
